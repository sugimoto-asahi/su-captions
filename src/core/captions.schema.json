{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Captions JSON Schema",
    "type": "object",
    "properties": {
        "tracks": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/track"
            }
        }
    },
    "additionalProperties": false,
    "$defs": {
        "track": {
            "type": "object",
            "properties": {
                "name": {
                    "description": "Name of track (unique identifier)",
                    "type": "string"
                },
                "captions": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/caption"
                    }
                }
            },
            "required": [
                "name",
                "captions"
            ],
            "additionalProperties": false
        },
        "caption": {
            "type": "object",
            "description": "Single caption instance",
            "properties": {
                "startTimecode": {
                    "$ref": "#/$defs/timecode"
                },
                "endTimecode": {
                    "$ref": "#/$defs/timecode"
                },
                "content": {
                    "type": "string"
                }
            },
            "required": [
                "startTimecode",
                "endTimecode",
                "content"
            ],
            "additionalProperties": false
        },
        "timecode": {
            "type": "object",
            "description": "SMPTE-style timecode",
            "properties": {
                "hours": { "type": "integer" },
                "minutes": { "type": "integer" },
                "seconds": { "type": "integer" },
                "frames": { "type": "integer" }
            },
            "required": ["hours", "minutes", "seconds", "frames"],
            "additionalProperties": false
        }
    }
}